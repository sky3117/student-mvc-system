<!DOCTYPE html>
<html>

<head>
        <meta charset="UTF-8" />
        <title>
                <%= heading %>
        </title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>

<body class="bg-light">
        <div class="container py-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                        <h1>
                                <%= heading %>
                        </h1>
                        <a class="btn btn-outline-secondary" href="/">Back</a>
                </div>

                <% if (errors && errors.length) { %>
                        <div class="alert alert-danger">
                                <ul class="mb-0">
                                        <% errors.forEach(err=> { %>
                                                <li>
                                                        <%= err %>
                                                </li>
                                                <% }); %>
                                </ul>
                        </div>
                        <% } %>

                                <form action="<%= formAction %>" method="POST" class="row g-3">
                                        <div class="col-md-6">
                                                <label class="form-label">Name</label>
                                                <input name="name" class="form-control" required
                                                        value="<%= student.name || '' %>">
                                        </div>
                                        <div class="col-md-6">
                                                <label class="form-label">Roll</label>
                                                <input name="roll" type="number" class="form-control" required
                                                        value="<%= student.roll || '' %>">
                                        </div>
                                        <div class="col-md-6">
                                                <label class="form-label">Email</label>
                                                <input name="email" type="email" class="form-control" required
                                                        value="<%= student.email || '' %>">
                                        </div>
                                        <div class="col-md-3">
                                                <label class="form-label">Age</label>
                                                <input name="age" type="number" class="form-control" required min="5"
                                                        max="100" value="<%= student.age || '' %>">
                                        </div>
                                        <div class="col-md-3">
                                                <label class="form-label">Grade</label>
                                                <select name="grade" class="form-select">
                                                        <% ['A','B','C','D','E','F'].forEach(g=> { %>
                                                                <option value="<%= g %>" <%=student.grade===g
                                                                        ? 'selected' : '' %>><%= g %>
                                                                </option>
                                                                <% }) %>
                                                </select>
                                        </div>
                                        <div class="col-12">
                                                <button class="btn btn-primary" type="submit">
                                                        <%= heading %>
                                                </button>
                                        </div>
                                </form>
        </div>
</body>

</html>